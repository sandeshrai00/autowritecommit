{
  "name": "auto-commit-message",
  "displayName": "Auto Commit Message",
  "description": "AI-powered conventional commit message generator with live status bar counter",
  "version": "2.0.0",
  "publisher": "autocommit",
  "license": "MIT",
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "message",
    "conventional-commits",
    "auto-generate",
    "status-bar"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "auto-commit-message.generateMessage",
        "title": "Generate Commit Message",
        "category": "Auto Commit",
        "icon": "$(git-commit)"
      },
      {
        "command": "auto-commit-message.stageAllAndCommit",
        "title": "Stage All & Generate Commit Message",
        "category": "Auto Commit",
        "icon": "$(check-all)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "auto-commit-message.generateMessage",
          "when": "scmProvider == git",
          "group": "navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "auto-commit-message.generateMessage",
          "when": "workspaceHasConfiguration"
        },
        {
          "command": "auto-commit-message.stageAllAndCommit",
          "when": "workspaceHasConfiguration"
        }
      ]
    },
    "configuration": {
      "title": "Auto Commit Message",
      "properties": {
        "autoCommitMessage.useEmoji": {
          "type": "boolean",
          "default": false,
          "description": "Include emoji prefix in commit messages (e.g. ✨ feat: add widget)"
        },
        "autoCommitMessage.maxLength": {
          "type": "number",
          "default": 72,
          "description": "Maximum character length for the commit subject line"
        },
        "autoCommitMessage.showStatusBarCount": {
          "type": "boolean",
          "default": true,
          "description": "Show change count in the status bar button"
        },
        "autoCommitMessage.autoStageOnGenerate": {
          "type": "boolean",
          "default": false,
          "description": "Automatically stage all changes when generating a commit message"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "20.10.0",
    "@types/vscode": "^1.97.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.2"
  }
}
